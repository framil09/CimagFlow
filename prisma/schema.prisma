generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COLABORADOR
}

enum DocumentStatus {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum SignerStatus {
  PENDENTE
  ASSINADO
  RECUSADO
}

enum SignerType {
  FORNECEDOR
  PREFEITO
  JURIDICO
  TESTEMUNHA
  OUTRO
}

enum BidType {
  CHAMADA_PUBLICA
  COMPRA_DIRETA
  CONCORRENCIA
  CONCURSO
  CONVENIO
  CONVITE
  CREDENCIAMENTO
  DISPENSA
  INEXIGIBILIDADE
  LEILAO
  PREGAO
  PREGAO_ELETRONICO
  RATEIO
  TOMADA_PRECOS
}

enum BidStatus {
  ABERTO
  EM_ANDAMENTO
  ENCERRADO
  CANCELADO
  SUSPENSO
}

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(COLABORADOR)
  phone       String?
  photo       String?
  isActive    Boolean    @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents   Document[]
  templates   Template[]
  notifications Notification[]
  folders     Folder[]
  bids        Bid[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  content     String?        @db.Text
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  status      DocumentStatus @default(RASCUNHO)
  deadline    DateTime?
  message     String?
  reminderDays Int?          @default(3)
  folderId    String?
  bidId       String?
  templateId  String?
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator     User           @relation(fields: [createdBy], references: [id])
  folder      Folder?        @relation(fields: [folderId], references: [id])
  bid         Bid?           @relation(fields: [bidId], references: [id])
  template    Template?      @relation(fields: [templateId], references: [id])
  signers     DocumentSigner[]

  @@map("documents")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  variables   String[] @default([])
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User       @relation(fields: [createdBy], references: [id])
  documents   Document[]

  @@map("templates")
}

model Signer {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String?
  cpf          String?
  type         SignerType @default(OUTRO)
  municipality String?
  company      String?
  prefectureId String?
  companyId    String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  companyRef   Company?    @relation(fields: [companyId], references: [id])
  documentSigners DocumentSigner[]

  @@map("signers")
}

model DocumentSigner {
  id          String       @id @default(cuid())
  documentId  String
  signerId    String
  status      SignerStatus @default(PENDENTE)
  signedAt    DateTime?
  token       String       @unique @default(cuid())
  tokenUsedAt DateTime?
  order       Int          @default(0)
  ipAddress   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer      Signer       @relation(fields: [signerId], references: [id])

  @@map("document_signers")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Folder {
  id           String   @id @default(cuid())
  name         String
  description  String?
  parentId     String?
  prefectureId String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent       Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     Folder[]    @relation("FolderHierarchy")
  creator      User        @relation(fields: [createdBy], references: [id])
  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  documents    Document[]

  @@map("folders")
}

model Prefecture {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?
  address     String?
  city        String
  state       String
  phone       String?
  email       String?
  mayorName   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signers     Signer[]
  bids        Bid[]
  folders     Folder[]

  @@map("prefectures")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  tradeName     String?
  cnpj          String?
  address       String?
  number        String?
  complement    String?
  cep           String?
  city          String?
  state         String?
  phone         String?
  email         String?
  contactName   String?
  isCredenciada Boolean  @default(false)
  bidId         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bid           Bid?     @relation(fields: [bidId], references: [id])
  signers       Signer[]

  @@map("companies")
}

model Bid {
  id           String    @id @default(cuid())
  number       String
  title        String
  description  String?   @db.Text
  type         BidType   @default(PREGAO_ELETRONICO)
  status       BidStatus @default(ABERTO)
  openingDate  DateTime?
  closingDate  DateTime?
  value        Float?
  prefectureId String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  creator      User        @relation(fields: [createdBy], references: [id])
  documents    Document[]
  companies    Company[]

  @@map("bids")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SIGN
  REFUSE
  SEND
  CANCEL
  LOGIN
  LOGOUT
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  userName    String?
  action      AuditAction
  entity      String
  entityId    String?
  entityName  String?
  details     String?     @db.Text
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
