generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COLABORADOR
}

enum DocumentStatus {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum SignerStatus {
  PENDENTE
  ASSINADO
  RECUSADO
}

enum SignerType {
  FORNECEDOR
  PREFEITO
  JURIDICO
  TESTEMUNHA
  OUTRO
}

enum BidType {
  CHAMADA_PUBLICA
  COMPRA_DIRETA
  CONCORRENCIA
  CONCURSO
  CONVENIO
  CONVITE
  CREDENCIAMENTO
  DISPENSA
  INEXIGIBILIDADE
  LEILAO
  PREGAO
  PREGAO_ELETRONICO
  RATEIO
  TOMADA_PRECOS
}

enum BidStatus {
  ABERTO
  EM_ANDAMENTO
  ENCERRADO
  CANCELADO
  SUSPENSO
}

enum DemandStatus {
  ABERTA
  EM_ANALISE
  EM_ANDAMENTO
  AGUARDANDO_RESPOSTA
  CONCLUIDA
  CANCELADA
}

enum DemandPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(COLABORADOR)
  phone       String?
  photo       String?
  isActive    Boolean    @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents   Document[]
  templates   Template[]
  notifications Notification[]
  folders     Folder[]
  bids        Bid[]
  auditLogs   AuditLog[]
  demandsCreated     Demand[] @relation("DemandCreator")
  demandsAssigned    Demand[] @relation("DemandAssigned")
  minutesCreated     MinutesOfMeeting[] @relation("MinuteCreator")
  minutesApproved    MinutesOfMeeting[] @relation("MinuteApprover")
  adhesionReviews    MinuteAdhesion[]

  @@map("users")
}

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  content     String?        @db.Text
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  status      DocumentStatus @default(RASCUNHO)
  deadline    DateTime?
  message     String?
  reminderDays Int?          @default(3)
  folderId    String?
  bidId       String?
  templateId  String?
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator     User           @relation(fields: [createdBy], references: [id])
  folder      Folder?        @relation(fields: [folderId], references: [id])
  bid         Bid?           @relation(fields: [bidId], references: [id])
  template    Template?      @relation(fields: [templateId], references: [id])
  signers     DocumentSigner[]

  @@map("documents")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  variables   String[] @default([])
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User       @relation(fields: [createdBy], references: [id])
  documents   Document[]

  @@map("templates")
}

model Signer {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String?
  cpf          String?
  type         SignerType @default(OUTRO)
  municipality String?
  company      String?
  prefectureId String?
  companyId    String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  companyRef   Company?    @relation(fields: [companyId], references: [id])
  documentSigners DocumentSigner[]

  @@map("signers")
}

model DocumentSigner {
  id          String       @id @default(cuid())
  documentId  String
  signerId    String
  status      SignerStatus @default(PENDENTE)
  signedAt    DateTime?
  token       String       @unique @default(cuid())
  tokenUsedAt DateTime?
  order       Int          @default(0)
  ipAddress   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer      Signer       @relation(fields: [signerId], references: [id])

  @@map("document_signers")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Folder {
  id           String   @id @default(cuid())
  name         String
  description  String?
  parentId     String?
  prefectureId String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent       Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     Folder[]    @relation("FolderHierarchy")
  creator      User        @relation(fields: [createdBy], references: [id])
  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  documents    Document[]

  @@map("folders")
}

model Prefecture {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?
  address     String?
  city        String
  state       String
  phone       String?
  email       String?
  mayorName   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signers     Signer[]
  demands     Demand[]
  bids        Bid[]
  folders     Folder[]
  minutes     MinutesOfMeeting[]

  @@map("prefectures")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  tradeName     String?
  cnpj          String?
  address       String?
  number        String?
  complement    String?
  cep           String?
  city          String?
  state         String?
  phone         String?
  email         String?
  contactName   String?
  isCredenciada Boolean  @default(false)
  bidId         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bid           Bid?     @relation(fields: [bidId], references: [id])
  signers       Signer[]

  @@map("companies")
}

model Bid {
  id           String    @id @default(cuid())
  number       String
  title        String
  description  String?   @db.Text
  type         BidType   @default(PREGAO_ELETRONICO)
  status       BidStatus @default(ABERTO)
  openingDate  DateTime?
  closingDate  DateTime?
  value        Float?
  prefectureId String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  prefecture   Prefecture? @relation(fields: [prefectureId], references: [id])
  creator      User        @relation(fields: [createdBy], references: [id])
  documents    Document[]
  companies    Company[]
  minutes      MinutesOfMeeting[]

  @@map("bids")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SIGN
  REFUSE
  SEND
  CANCEL
  LOGIN
  LOGOUT
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  userName    String?
  action      AuditAction
  entity      String
  entityId    String?
  entityName  String?
  details     String?     @db.Text
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Demand {
  id              String         @id @default(cuid())
  protocolNumber  String         @unique
  title           String
  description     String         @db.Text
  status          DemandStatus   @default(ABERTA)
  priority        DemandPriority @default(MEDIA)
  
  // Informações do Requerente
  requesterName   String
  requesterEmail  String
  requesterPhone  String?
  requesterCpf    String?
  dotacao         String?
  
  // Relacionamentos
  prefectureId    String?
  assignedToId    String?
  createdBy       String?
  
  // Flags
  publicSubmission Boolean       @default(false)
  
  // Datas
  dueDate         DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Anexos e observações
  attachments     String[]       @default([])
  responseAttachments String[]   @default([])
  internalNotes   String?        @db.Text
  resolution      String?        @db.Text
  responseComment String?        @db.Text
  
  // Relacionamentos
  prefecture      Prefecture?    @relation(fields: [prefectureId], references: [id])
  assignedTo      User?          @relation("DemandAssigned", fields: [assignedToId], references: [id])
  creator         User?          @relation("DemandCreator", fields: [createdBy], references: [id])
  history         DemandHistory[]
  
  @@index([protocolNumber])
  @@index([status])
  @@index([prefectureId])
  @@index([createdAt])
  @@map("demands")
}

model DemandHistory {
  id          String       @id @default(cuid())
  demandId    String
  userId      String?
  userName    String
  action      String
  oldValue    String?
  newValue    String?
  comment     String?      @db.Text
  createdAt   DateTime     @default(now())
  
  demand      Demand       @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  @@index([demandId])
  @@index([createdAt])
  @@map("demand_history")
}

enum MinuteStatus {
  RASCUNHO
  APROVADA
  PUBLICADA
  ARQUIVADA
}

enum MinuteType {
  ORDINARIA
  EXTRAORDINARIA
  ESPECIAL
  SOLENE
}

model MinutesOfMeeting {
  id              String        @id @default(cuid())
  number          String        @unique
  title           String
  description     String?       @db.Text
  type            MinuteType    @default(ORDINARIA)
  status          MinuteStatus  @default(RASCUNHO)
  meetingDate     DateTime
  startTime       String?
  endTime         String?
  location        String?
  participants    String[]      @default([])
  content         String?       @db.Text
  decisions       String?       @db.Text
  attachments     String[]      @default([])
  
  // Campos para Ata de Registro de Preço
  isPriceRegistry Boolean       @default(false)
  validityStartDate DateTime?
  validityEndDate   DateTime?
  isPublic        Boolean       @default(false)
  allowAdhesion   Boolean       @default(false)
  priceValue      Float?
  items           String?       @db.Text
  
  prefectureId    String?
  bidId           String?
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  prefecture      Prefecture?   @relation(fields: [prefectureId], references: [id])
  bid             Bid?          @relation(fields: [bidId], references: [id])
  creator         User          @relation("MinuteCreator", fields: [createdBy], references: [id])
  approver        User?         @relation("MinuteApprover", fields: [approvedBy], references: [id])
  adhesions       MinuteAdhesion[]
  
  @@index([number])
  @@index([status])
  @@index([prefectureId])
  @@index([meetingDate])
  @@index([isPriceRegistry])
  @@index([isPublic])
  @@map("minutes_of_meeting")
}

enum AdhesionStatus {
  PENDENTE
  APROVADA
  REJEITADA
  CANCELADA
}

model MinuteAdhesion {
  id                String         @id @default(cuid())
  minuteId          String
  
  // Dados do solicitante
  requesterName     String
  requesterEmail    String
  requesterPhone    String?
  requesterCpf      String?
  requesterCnpj     String?
  companyName       String?
  position          String?
  
  // Dados da adesão
  status            AdhesionStatus @default(PENDENTE)
  requestDate       DateTime       @default(now())
  justification     String?        @db.Text
  attachments       String[]       @default([])
  
  // Aprovação/Rejeição
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewComment     String?        @db.Text
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  minute            MinutesOfMeeting @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  reviewer          User?            @relation(fields: [reviewedBy], references: [id])
  
  @@index([minuteId])
  @@index([status])
  @@index([requesterEmail])
  @@map("minute_adhesions")
}
