# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database Configuration
# For production, use your PostgreSQL database URL
DATABASE_URL=postgresql://user:password@host:port/database

# AWS Configuration (optional for file storage)
AWS_PROFILE=hosted_storage
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=your-folder/
ABACUSAI_API_KEY=your-api-key

# Application IDs (optional)
WEB_APP_ID=your-web-app-id
NOTIF_ID_DOCUMENTO_ENVIADO_PARA_ASSINATURA=your-notif-id
NOTIF_ID_LEMBRETE_DE_ASSINATURA_PENDENTE=your-notif-id
NOTIF_ID_DOCUMENTO_COMPLETAMENTE_ASSINADO=your-notif-id
